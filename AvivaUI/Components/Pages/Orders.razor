@page "/orders"
@namespace AvivaUI.Components.Pages
@using AvivaLibrary.Models
@using AvivaLibrary.Models.Responses
@using Radzen
@using Radzen.Blazor
@inject NotificationService notificationService
@inject DialogService dialogService

<div class="aviva-layout">


    @* ── Main content ── *@
    <div class="aviva-main">

        <h2 class="page-title">Orders</h2>

        <RadzenDataGrid Data="@orders"
                        TItem="OrderResponse"
                        AllowPaging="true"
                        PageSize="6"
                        AllowSorting="true"
                        class="aviva-grid">
            <Columns>

                @* Order ID *@
                <RadzenDataGridColumn TItem="OrderResponse"
                                      Property="OrderId"
                                      Title="Order ID"
                                      Width="150px" />

                @* Date *@
                <RadzenDataGridColumn TItem="OrderResponse"
                                      Property="CreatedDate"
                                      Title="Date"
                                      Width="110px"
                                      FormatString="{0:dd/MM/yyyy}" />

                @* Description *@
                <RadzenDataGridColumn TItem="OrderResponse"
                                      Property="Method"
                                      Title="Pay with"
                                      Width="110px" />

                <RadzenDataGridColumn TItem="OrderResponse"
                                      Property="Status"
                                      Title="Status" 
                                      Width="110px" />
                @* Amount *@
                <RadzenDataGridColumn TItem="OrderResponse"
                                      Property="Amount"
                                      Title="Amount"
                                      Width="110px"
                                      TextAlign="TextAlign.Right">
                    <Template Context="row">
                        @row.Amount.ToString("C2")
                    </Template>
                </RadzenDataGridColumn>

                @* Product Quantities 
                <RadzenDataGridColumn TItem="OrderResponse"
                                      Property="products.ProductQuantities"
                                      Title="Qty"
                                      Width="70px"
                                      TextAlign="TextAlign.Center" />
*@
                @* Paid 
                <RadzenDataGridColumn TItem="Order"
                                      Property="Paid"
                                      Title="Paid"
                                      Width="90px"
                                      TextAlign="TextAlign.Center">
                    <Template Context="row">
                        <RadzenBadge Text="@(row.Paid ? "Yes" : "No")"
                                     BadgeStyle="@(row.Paid ? BadgeStyle.Success : BadgeStyle.Danger)"
                                     Shade="Shade.Lighter" />
                    </Template>
                </RadzenDataGridColumn>

*@
                @* Show Details button *@
                <RadzenDataGridColumn TItem="OrderResponse"
                                      Title="Details"
                                      Width="110px"
                                      Sortable="false"
                                      Filterable="false"
                                      TextAlign="TextAlign.Center">
                    <Template Context="row">
                        <RadzenButton Text="Details"
                                      Icon="visibility"
                                      ButtonStyle="ButtonStyle.Info"
                                      Shade="Shade.Lighter"
                                      Size="ButtonSize.Small"
                                      Click="@(() => ShowDetails(row))" />
                    </Template>

                </RadzenDataGridColumn>

                @* Pay Order button *@
                <RadzenDataGridColumn TItem="OrderResponse"
                                      Title="Payment"
                                      Width="110px"
                                      Sortable="false"
                                      Filterable="false"
                                      TextAlign="TextAlign.Center">
                    <Template Context="row">
                        <RadzenButton Text="Pay"
                                      Icon="payment"
                                      ButtonStyle="ButtonStyle.Success"
                                      Shade="Shade.Lighter"
                                      Size="ButtonSize.Small"
                                      Disabled="@CheckIsPaid(row.Status)"
                                      Click="@(() => ConfirmPayment(row))" />
                    </Template>
                </RadzenDataGridColumn>

            </Columns>
        </RadzenDataGrid>

    </div>

   @*  @* ── Details dialog ── 
       if (_showDetails && selectedOrder != null)
    {
        <RadzenDialog>
            <div class="order-dialog">
                <h3>Order #@selectedOrder.OrderId</h3>
                <hr />
                <table class="dialog-table">
                    <tr><td>Date</td>        <td>@selectedOrder.CreatedDate.ToString("dd/MM/yyyy")</td></tr>
                    <tr><td>Payment Provider</td> <td>@selectedOrder.ProviderName</td></tr>
                    <tr><td>Amount</td>      <td>@selectedOrder.Amount.ToString("C2")</td></tr>
                    <tr><td>Status</td>        <td>@(selectedOrder.Status)</td></tr>
                </table>
                <div class="dialog-actions">
                    <RadzenButton Text="Close"
                                  ButtonStyle="ButtonStyle.Secondary"
                                  Click="@(() => _showDetails = false)" />
                </div>
            </div>
        </RadzenDialog>
    } *@

</div>
